# ======================
# RISKISM Configuration
# ======================

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_FAST_MODELS=gemini-2.5-flash,gemini-2.0-flash
GEMINI_REASONING_MODELS=gemini-2.5-pro,gemini-2.5-flash,gemini-2.0-flash
GEMINI_FALLBACK_MODELS=gemini-2.5-flash,gemini-2.0-flash

# Firebase Auth
FIREBASE_PROJECT_ID=
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=
FIREBASE_SERVICE_ACCOUNT_PATH=
# Alternative to FIREBASE_SERVICE_ACCOUNT_PATH
FIREBASE_SERVICE_ACCOUNT_JSON=

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=riskism
POSTGRES_USER=riskism
POSTGRES_PASSWORD=riskism_secret_2024

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# App
APP_ENV=development
APP_SECRET_KEY=change-me-in-production
SECRET_KEY=change-me-in-production
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Market Config
MARKET_TIMEZONE=Asia/Ho_Chi_Minh
MORNING_ANALYSIS_TIME=08:30
AFTERNOON_REVIEW_TIME=15:30
